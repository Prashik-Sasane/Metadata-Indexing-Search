# Environment Configuration
NODE_ENV=development
PORT=3000

# PostgreSQL connection string
# Local example:
# DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/mydatabase
DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/mydatabase

# Set to true only for managed PostgreSQL services that require TLS.
DATABASE_SSL=false

# Redis Cache
REDIS_URL=redis://localhost:6379

# Kafka (optional / future)
KAFKA_BROKER=localhost:9092

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET=metadata-search-files

# Comma-separated list of allowed origins; omit or set to '*' to allow all.
# Example: CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# Request body size limit
JSON_LIMIT=1mb

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
